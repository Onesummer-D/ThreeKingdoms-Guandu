    dialogueText: "\u5EFA\u5B89\u4E94\u5E74\u79CB\u516B\u6708\uFF0C\u5B98\u6E21\u3002\u9EC4\u6CB3\u5954\u6D41\uFF0C\u51B2\u4E0D\u6563\u4E24\u5CB8\u6740\u6C14\u3002\u8881\u7ECD\u8FDE\u8425\u6570\u5341\u91CC\uFF0C\u66F4\u7B51\u571F\u5C71\u3001\u67B6\u9AD8\u6A79\uFF0C\u5F13\u5F29\u624B\u5C45\u9AD8\u4E34\u4E0B\uFF0C\u77E2\u4E0B\u5982\u96E8\u3002\u66F9\u519B\u9876\u76FE\u53D6\u6C34\uFF0C\u4EA6\u5E38\u6A2A\u6B7B\u3002\u66F9\u64CD\u770B\u7740\u7A7F\u900F\u5E10\u5E55\u3001\u9489\u5165\u6848\u51E0\u7684\u7BAD\u77E2\uFF0C\u591C\u98CE\u547C\u5578\u5982\u9B3C\u54ED\u3002\u82E5\u4E0D\u80FD\u7834\u6B64\u7A7A\u4E2D\u4F18\u52BF\uFF0C\u8FD9\u56DB\u4E07\u5175\uFF0C\u6015\u8981\u5168\u5C04\u6B7B\u5728\u8FD9\u70C2\u6CE5\u5730\u91CC\u3002"
