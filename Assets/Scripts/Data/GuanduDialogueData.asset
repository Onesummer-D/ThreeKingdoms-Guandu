    dialogueText: "\u66F9\u64CD\u5C06\u51B3\u6218\u5730\u9501\u5B9A\u5B98\u6E21\uFF0C\u8DDD\u8BB8\u90FD\u4EC587\u516C\u91CC\uFF0C\u627C\u8881\u7ECD\u5357\u4E0B\u54BD\u5589\u3002\u6B64\u9009\u62E9\u62B5\u6D88\u5175\u529B\u52A3\u52BF\uFF0C\u53D1\u6325\u5185\u7EBF\u4F18\u52BF\u3002\u8881\u7ECD\"\u597D\u8C0B\u65E0\u65AD\"\uFF0C\u66F9\u64CD\u52A1\u5B9E\u679C\u51B3\u3002\u6027\u683C\u5DEE\u5F02\uFF0C\u5DF2\u6CE8\u5B9A\u8D70\u5411\u3002\u524D\u54E8\u6218\u4E2D\uFF0C\u5173\u7FBD\u65A9\u989C\u826F\uFF0C\u66F9\u64CD\u7834\u6587\u4E11\uFF0C\u632B\u8881\u519B\u9510\u6C14\u3002\u7136\u771F\u6B63\u7684\u8F83\u91CF\uFF0C\u662F\u540E\u52E4\u4E0E\u5FCD\u8010\u7684\u7EDE\u6740\u3002"
