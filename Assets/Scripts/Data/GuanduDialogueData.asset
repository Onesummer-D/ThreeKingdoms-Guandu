    dialogueText: "\u8FD9\u4E00\u591C\uFF0C\u6CB3\u5317\u56DB\u5DDE\u7684\u4E3B\u5E05\u88AB\u4FD8\uFF0C\u8881\u519B\u6307\u6325\u7CFB\u7EDF\u5F7B\u5E95\u762B\u75EA\u3002\u524D\u7EBF\u653B\u6253\u5B98\u6E21\u7684\u5F20\u90C3\u3001\u9AD8\u89C8\u95FB\u8BAF\uFF0C\u76F4\u63A5\u5728\u9635\u524D\u5012\u6208\uFF1B\u4E4C\u5DE2\u7684\u6DF3\u4E8E\u743C\u66F4\u662F\u4E0D\u6218\u800C\u964D\u3002\r\n\r\n\u8881\u7ECD\u5927\u519B\uFF0C\u5728\u4E00\u591C\u4E4B\u95F4\u571F\u5D29\u74E6\u89E3\uFF0C\u4E3B\u5C06\u53D7\u8FB1\uFF0C\u5175\u4E0D\u8840\u5203\u3002\r\n\r\n\u6B64\u6218\u4E4B\u540E\uFF0C\u539F\u672C\u9700\u8981\u8017\u65F6\u6570\u5E74\u7684\u5317\u65B9\u7EDF\u4E00\u6218\u4E89\uFF0C\u7ADF\u56E0\u8FD9\u96F7\u9706\u4E07\u94A7\u7684\u4E00\u591C\uFF0C\u800C\u63D0\u524D\u6570\u5E74\u5B8C\u6210\u3002\r\n\r\n\u66F9\u64CD\u7AD9\u5728\u9EC4\u6CB3\u4E4B\u5DC5\uFF0C\u4FEF\u77B0\u8FD9\u7247\u5DF2\u5C3D\u5165\u56CA\u4E2D\u7684\u571F\u5730\u3002\u5929\u4E0B\u4E00\u7EDF\u7684\u6B65\u4F10\uFF0C\u5FEB\u5F97\u8FDE\u4E16\u4EBA\u90FD\u6765\u4E0D\u53CA\u53CD\u5E94\u3002\r"
