  - nodeId: 100005
    dialogueText: "\u4E24\u519B\u6700\u7EC8\u5728\u5B98\u6E21\u5F62\u6210\u6F2B\u957F\u5BF9\u5CD9\u3002\u6218\u5F79\u8FDB\u5165\u5341\u6708\uFF0C\u66F9\u519B\u7CAE\u5C3D\uFF0C\u58EB\u5352\u75B2\u4E4F\uFF0C\u66F9\u64CD\u51E0\u4E4E\u52A8\u6447\u3002\u800C\u8881\u7ECD\u5C06\u5168\u519B\u7CAE\u8349\u56E4\u4E8E\u4E4C\u5DE2\uFF0C\u5B58\u7CAE\u4E07\u4F59\u8F66
      \u2014\u2014 \u8FD9\u6761\u4ECE\u6CB3\u5317\u5230\u4E4C\u5DE2\u7684\u6F2B\u957F\u8865\u7ED9\u7EBF\uFF0C\u6210\u4E86\u4ED6\u96C4\u539A\u5B9E\u529B\u4E0B\u6700\u81F4\u547D\u7684
      \u201C\u963F\u5580\u7409\u65AF\u4E4B\u8E35\u201D\u3002\r\n\r\n\u6B64\u65F6\uFF0C\u8C0B\u58EB\u8BB8\u6538\u56E0\u5BB6\u4EBA\u88AB\u6536\u6355\u800C\u53DB\u9003\u66F9\u8425\uFF0C\u5E26\u6765\u4E86\u6539\u53D8\u5386\u53F2\u7684\u60C5\u62A5\uFF1A\u201C\u8881\u519B\u8F8E\u91CD\u4E07\u4F59\u4E58\uFF0C\u5C6F\u4E8E\u4E4C\u5DE2\uFF0C\u5B88\u519B\u65E0\u5907\u3002\u201D\r\n\r\n\u4E00\u573A\u711A\u70E7\u7CAE\u8349\u3001\u6539\u5199\u5317\u65B9\u547D\u8FD0\u7684\u5947\u88AD\uFF0C\u5373\u5C06\u5728\u591C\u5E55\u4E0B\u4E0A\u6F14\u3002\u5B98\u6E21\u4E4B\u6218\u7684\u80DC\u8D1F\u5929\u5E73\uFF0C\u60AC\u4E8E\u4E00\u7EBF\u3002\r"
