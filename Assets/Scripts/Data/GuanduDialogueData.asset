  - nodeId: 100003
    dialogueText: "\u6218\u4E89\u7684\u80DC\u8D1F\uFF0C\u5F80\u5F80\u5728\u6218\u9F13\u64C2\u54CD\u524D\u5DF2\u7531\u7EDF\u5E05\u6027\u683C\u6084\u7136\u4E66\u5199\u3002\r\n\r\n\u8881\u7ECD\u51FA\u8EAB\u9876\u7EA7\u95E8\u9600\uFF0C\u5374\u56E0\u5EB6\u51FA\u8EAB\u4EFD\u5185\u5FC3\u654F\u611F\u3002\u4ED6
      \u201C\u597D\u8C0B\u65E0\u65AD\u201D\uFF0C\u9EBE\u4E0B\u8C0B\u58EB\u5982\u4E91\uFF0C\u6CAE\u6388\u3001\u7530\u4E30\u5C61\u732E\u8FDC\u89C1\u5374\u62D2\u7EDD\u91C7\u7EB3\uFF1B\u4ED6\u5916\u5BBD\u5185\u5FCC\uFF0C\u8C0B\u58EB\u8BB8\u6538\u56E0\u5BB6\u4EBA\u72AF\u6CD5\u88AB\u8FFD\u7A76\uFF0C\u6124\u800C\u6295\u66F9\u3002\r\n\r\n\u66F9\u64CD\u5219\u6070\u6070\u76F8\u53CD\uFF0C\u51FA\u8EAB
      \u201C\u8D58\u9609\u9057\u4E11\u201D \u6FC0\u53D1\u4E86\u4ED6\u52A1\u5B9E\u6218\u7684\u7CBE\u795E\uFF0C\u4ED6\u77E5\u4EBA\u5584\u4EFB\uFF0C\u9EBE\u4E0B\u805A\u96C6\u8340\u5F67\u3001\u90ED\u5609\u7B49\u4E00\u6D41\u4EBA\u624D\u3002\r"
