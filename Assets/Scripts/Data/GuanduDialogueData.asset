    dialogueText: "\u4E4C\u5DE2\u7684\u706B\uFF0C\u7EC8\u7A76\u662F\u70E7\u5F97\u592A\u6162\u4E86\u3002\r\n\r\n\u66F9\u64CD\u7559\u4E0B\u7684\u4E09\u5343\u5175\u529B\uFF0C\u6B63\u5982\u4E00\u628A\u88AB\u78E8\u53BB\u4E86\u950B\u8292\u7684\u949D\u5200\uFF0C\u780D\u5728\u6DF3\u4E8E\u743C\u62FC\u6B7B\u4E00\u640F\u7684\u76FE\u724C\u4E0A\u3002\u5206\u5175\u4E4B\u7B56\uFF0C\u867D\u7F13\u89E3\u4E86\u540E\u65B9\u4E4B\u5FE7\uFF0C\u5374\u4E5F\u8BA9\u4E4C\u5DE2\u9635\u524D\u7684\u653B\u52BF\u51FA\u73B0\u4E86\u81F4\u547D\u7684\u505C\u6EDE\u3002\r\n\u8881\u7ECD\u7684\u63F4\u9A91\u5982\u4E4C\u4E91\u538B\u5883\uFF0C\u751A\u81F3\u8D81\u7740\u66F9\u519B\u9635\u578B\u7A00\u758F\u4E4B\u65F6\uFF0C\u53CD\u6251\u5C06\u90E8\u5206\u706B\u5934\u6251\u706D\u3002\r\n\r\n\u4E3A\u4E86\u4E0D\u8BA9\u8FD9\u4E09\u5343\u79CD\u5B50\u5168\u519B\u8986\u6CA1\uFF0C\u66F9\u64CD\u4E0D\u5F97\u4E0D\u5728\u7CAE\u8349\u5C1A\u672A\u5C3D\u6BC1\u7684\u60C5\u51B5\u4E0B\uFF0C\u542B\u6068\u4E0B\u4EE4\u64A4\u9000\u3002\u800C\u5728\u5B98\u6E21\u65B9\u5411\uFF0C\u5C3D\u7BA1\u66F9\u6D2A\u3001\u8BB8\u891A\u6D74\u8840\u594B\u6218\uFF0C\u4F46\u9762\u5BF9\u5F20\u90C3\u3001\u9AD8\u89C8\u8FD9\u822C\u5F53\u4E16\u540D\u5C06\u7684\u731B\u653B\uFF0C\u90A3\u4E24\u5343\u63F4\u519B\u7EC8\u7A76\u662F\u676F\u6C34\u8F66\u85AA\u3002\u5927\u8425\u5916\u5899\u88AB\u8F70\u584C\uFF0C\u8F8E\u91CD\u7CAE\u8349\u5728\u6DF7\u6218\u4E2D\u88AB\u52AB\u63A0\u4E00\u7A7A\u3002\r"
