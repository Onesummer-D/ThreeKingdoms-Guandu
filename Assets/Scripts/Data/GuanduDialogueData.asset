    dialogueText: "\u6570\u65E5\u540E\uFF0C\u4E4C\u5DE2\u65B9\u5411\u3002\r\n\r\n\u8881\u7ECD\u4E4C\u5DE2\u7CAE\u8349\u635F\u5931\u60E8\u91CD\uFF0C\u4F46\u672A\u81F3\u6839\u672C\uFF1B\u5176\u4E3B\u529B\u5927\u519B\u867D\u53D7\u9707\u52A8\uFF0C\u5374\u672A\u5D29\u6E83\u3002\u800C\u66F9\u64CD\u7684\u519B\u961F\uFF0C\u5728\u4E4C\u5DE2\u653B\u575A\u4E0E\u56DE\u9632\u5927\u8425\u7684\u4E24\u7EBF\u6D88\u8017\u4E2D\uFF0C\u5DF2\u6D41\u5C3D\u4E86\u6700\u540E\u4E00\u6EF4\u8840\u3002\u5175\u529B\u6298\u635F\u4E25\u91CD\uFF0C\u4EC5\u5B58\u7684\u7CAE\u8349\u4E5F\u5728\u884C\u519B\u4E2D\u6D88\u8017\u6B86\u5C3D\u3002
