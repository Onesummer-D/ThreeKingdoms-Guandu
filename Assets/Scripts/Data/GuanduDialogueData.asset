  nodes:
  - nodeId: 100001
    dialogueText: "\u5EFA\u5B89\u4E94\u5E74\uFF08\u516C\u5143 200 \u5E74\uFF09\u521D\u79CB\uFF0C\u9EC4\u6CB3\u4E4B\u7554\u5F25\u6F2B\u7740\u5C71\u96E8\u6B32\u6765\u7684\u8083\u6740\u3002\u5386\u7ECF\u6570\u5E74\u517C\u5E76\u6218\u4E89\uFF0C\u4E2D\u56FD\u5317\u65B9\u53EA\u5269\u4E0B\u4E24\u80A1\u529B\u91CF\u9694\u6CB3\u5BF9\u5CD9
      \u2014\u2014 \u96C4\u8E1E\u6CB3\u5317\u7684\u8881\u7ECD\u4E0E \u201C\u631F\u5929\u5B50\u4EE5\u4EE4\u8BF8\u4FAF\u201D
      \u7684\u66F9\u64CD\u3002\u51B3\u5B9A\u5929\u4E0B\u547D\u8FD0\u7684\u5B98\u6E21\u4E4B\u6218\uFF0C\u5373\u5C06\u62C9\u5F00\u5E8F\u5E55\u3002"
    backgroundImage: {fileID: 21300000, guid: 06fbd20bb10723344bd1176793ef2264, type: 3}
