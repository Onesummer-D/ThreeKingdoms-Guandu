  - nodeId: 100002
    dialogueText: "\u4ECE\u7EB8\u9762\u5B9E\u529B\u770B\uFF0C\u8FD9\u662F\u4E00\u573A\u8FD1\u4E4E\u4E00\u8FB9\u5012\u7684\u5BF9\u51B3\uFF1A\u8881\u7ECD\u96C6\u7ED3\u9752\u3001\u5180\u3001\u5E7D\u3001\u5E76\u56DB\u5DDE\u4E4B\u5175\uFF0C\u7EA6\u5341\u4E00\u4E07\u4EBA\uFF1B\u66F9\u64CD\u80FD\u6295\u5165\u524D\u7EBF\u7684\u5175\u529B\uFF0C\u4EC5\u7EA6\u4E24\u4E07\u4EBA\u3002\r\n\r\r\n\u8881\u7ECD\u5750\u62E5
      \u201C\u5929\u4E0B\u91CD\u8D44\u201D \u7684\u5180\u5DDE\uFF0C\u6218\u524D\u7CAE\u4ED3
      \u201C\u5806\u79EF\u5982\u5C71\uFF0C\u8DB3\u591F\u51E0\u5341\u4E07\u5927\u519B\u6D88\u8017\u6570\u5E74\u201D\u3002\u66F9\u64CD\u6240\u5904\u7684\u5156\u5DDE\u3001\u8C6B\u5DDE\u56E0\u6218\u4E71\u6C11\u751F\u51CB\u655D\uFF0C\u5B98\u6E21\u5BF9\u5CD9\u6700\u8270\u82E6\u65F6\uFF0C\u66F9\u519B\u7CAE\u8349\u4E00\u5EA6
      \u201C\u53EA\u591F\u5168\u519B\u5403\u4E00\u4E2A\u6708\u201D\uFF0C\u58EB\u5175\u4E0D\u5F97\u4E0D\u4EE5\u91CE\u83DC\u63BA\u7C9F\u7C73\u5145\u9965\u3002\r\n\r\n\u66F9\u64CD\u5C06\u51B3\u6218\u5730\u70B9\u9884\u8BBE\u4E8E\u5B98\u6E21\uFF0C\u582A\u79F0\u795E\u6765\u4E4B\u7B14\u3002\u6B64\u5904\u662F\u8BB8\u90FD\u5317\u9762\u5C4F\u969C\uFF0C\u627C\u4F4F\u8881\u7ECD\u5357\u4E0B\u54BD\u5589\uFF1B\u8DDD\u8BB8\u90FD\u4EC5\u7EA6
      87 \u516C\u91CC\uFF0C\u66F9\u519B\u8865\u7ED9\u7EBF\u77ED\u6377\u7262\u56FA\u3002\u800C\u8881\u7ECD\u7CAE\u8349\u9700\u4ECE\u6CB3\u5317\u90BA\u57CE\u8DE8\u8D8A\u9EC4\u6CB3\uFF0C\u6570\u767E\u91CC\u8FD0\u8F93\u635F\u8017\u5DE8\u5927\uFF0C\u6781\u6613\u53D7\u88AD\u3002\u5B98\u6E21\u5468\u8FB9\u6CB3\u7F51\u5BC6\u5E03\uFF0C\u66F4\u9650\u5236\u4E86\u8881\u7ECD\u9A91\u5175\u7684\u673A\u52A8
      \u2014\u2014 \u66F9\u64CD\u9009\u62E9\u4E86\u4E00\u4E2A\u80FD\u6700\u5927\u9650\u5EA6\u62B5\u6D88\u654C\u519B\u4F18\u52BF\u7684
      \u201C\u4E3B\u573A\u201D\u3002\r"
